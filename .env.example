# Cấu hình API Keys bảo mật cho dự án RT-SWT-005 (Group 4)
# Copy file này, đổi tên thành `.env` và điền key của bạn vào.
# LƯU Ý: Không bao giờ commit file `.env` chứa key thật lên GitHub!

# 1. API Key của OpenRouter (Dùng cho Exploration Agent - DeepSeek-V3)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
EXPLORATION_MODEL_NAME=deepseek/deepseek-chat

# 2. Cấu hình Code Action Fixer (DeepSeek R1/Reasoner)
# Nếu bạn muốn gọi DeepSeek Native, hãy điền key vào đây. 
# Nếu bỏ trống, hệ thống sẽ tự động dùng chung key OpenRouter ở trên để gọi deepseek/deepseek-r1.
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-reasoner
